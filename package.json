{
  "name": "algovision",
  "displayName": "AlgoVision",
  "description": "Real-time interactive visualization of data structures and memory states during debugging.",
  "version": "1.0.0",
  "publisher": "algovision",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Debuggers",
    "Education",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "debugger",
    "visualization",
    "data structures",
    "education",
    "algorithms",
    "linked list",
    "binary tree",
    "array"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "algovision.visualize",
        "title": "AlgoVision: Open Visualizer Panel",
        "category": "AlgoVision"
      }
    ],
    "configuration": {
      "title": "AlgoVision",
      "properties": {
        "algovision.playbackSpeedMs": {
          "type": "number",
          "default": 400,
          "minimum": 100,
          "maximum": 5000,
          "description": "Auto-play step interval in milliseconds. Lower values step faster."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "npm --prefix webview-ui run build",
    "build:all": "npm run compile && npm run build:webview",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "npm run test:unit",
    "test:unit": "vitest run src/**/*.unit.test.ts",
    "test:integration": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
